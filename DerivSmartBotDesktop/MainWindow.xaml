<Window x:Class="DerivSmartBotDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DerivSmartBotDesktop"
        xmlns:conv="clr-namespace:DerivSmartBotDesktop.Converters"
        Title="Deriv Smart Bot" Height="650" Width="1000">
    <Window.Resources>
        <conv:BoolToTextConnectedConverter x:Key="BoolToText_Connected" />
        <conv:BoolToTextBotConverter x:Key="BoolToText_Bot" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top bar -->
            <RowDefinition Height="*"/>
            <!-- Strategy performance -->
            <RowDefinition Height="2*"/>
            <!-- Trade history + skip reason -->
            <RowDefinition Height="*"/>
            <!-- Log -->
        </Grid.RowDefinitions>

        <!-- ===================== TOP BAR ===================== -->
        <Grid Grid.Row="0" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: balance, stats, profile, status, regime, rules -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <!-- Balance -->
                <StackPanel Width="220">
                    <TextBlock Text="Account Balance" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="{Binding Balance, StringFormat=C}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{Binding TodaysPL, StringFormat='Today P/L: {0:C}'}"
                               FontSize="12" Foreground="Gray"/>
                </StackPanel>

                <!-- Win rate / trades -->
                <StackPanel Width="200" Margin="20 0">
                    <TextBlock Text="Win Rate" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}" FontSize="18"/>
                    <TextBlock Text="{Binding TodaysTrades, StringFormat='Trades: {0}'}"
                               FontSize="12" Foreground="Gray"/>
                </StackPanel>

                <!-- Profile selector -->
                <StackPanel Width="200" Margin="20 0">
                    <TextBlock Text="Profile" FontSize="12" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              Width="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Connection & bot status lights -->
                <StackPanel Width="220" Margin="20 0">
                    <TextBlock Text="Status" FontSize="12" Foreground="Gray"/>
                    <!-- Connection -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="10" Height="10">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Red"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="LimeGreen"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToText_Connected}}"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                    <!-- Bot running -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Ellipse Width="10" Height="10">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Red"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="LimeGreen"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding IsRunning, Converter={StaticResource BoolToText_Bot}}"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Market regime & auto-pause reason -->
                <StackPanel Width="220" Margin="20 0">
                    <TextBlock Text="Market Regime" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="{Binding CurrentRegime}" FontSize="14"/>
                    <TextBlock Text="Auto-Pause Reason" FontSize="12" Foreground="Gray" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding AutoPauseReasonText}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Risk & Rules summary + heat + symbol -->
                <StackPanel Width="260" Margin="20 0">
                    <TextBlock Text="Risk &amp; Rules" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="{Binding RulesSummary}" FontSize="12" TextWrapping="Wrap"/>

                    <TextBlock Text="Active Symbol" FontSize="12" Foreground="Gray" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding ActiveSymbol}" FontSize="12"/>

                    <TextBlock Text="Market Heat" FontSize="12" Foreground="Gray" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding MarketHeatScore, StringFormat={}{0:F1}}"
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>

            <!-- RIGHT SIDE: StatusText + auto-start toggle + Start/Stop/Settings buttons -->
            <StackPanel Grid.Column="1" Margin="20 0 0 0" VerticalAlignment="Center">
                <!-- High-level status text -->
                <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="Bold" Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <!-- Disconnected -> red -->
                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <!-- Running -> green -->
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Foreground" Value="LimeGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Auto-start toggle -->
                <CheckBox Content="Auto-start when conditions are good"
                          IsChecked="{Binding AutoStartEnabled}"
                          VerticalAlignment="Center"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Margin="0 8 0 0" HorizontalAlignment="Right">
                    <Button Content="Start Bot" Width="100" Margin="0 0 10 0"
                            Click="StartBot_Click"/>
                    <Button Content="Stop Bot" Width="100" Margin="0 0 10 0"
                            Click="StopBot_Click"/>
                    <Button Content="Settings..." Width="100"
                            Click="Settings_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ===================== STRATEGY PERFORMANCE ===================== -->
        <GroupBox Grid.Row="1" Margin="0 0 0 10">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Strategy Performance"/>
                    <TextBlock Text="  |  Active: " Foreground="Gray"/>
                    <TextBlock Text="{Binding ActiveStrategyName}" FontWeight="Bold"/>
                </StackPanel>
            </GroupBox.Header>
            <DataGrid ItemsSource="{Binding StrategySummaries}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Strategy" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Win Rate (%)" Binding="{Binding WinRate, StringFormat={}{0:F1}}" Width="100"/>
                    <DataGridTextColumn Header="Trades" Binding="{Binding TotalTrades}" Width="80"/>
                    <DataGridTextColumn Header="Net P/L" Binding="{Binding NetPL, StringFormat={}{0:F2}}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- ===================== TRADE HISTORY + SKIP REASON ===================== -->
        <GroupBox Header="Trade History" Grid.Row="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Trade history grid -->
                <DataGrid ItemsSource="{Binding TradeHistory}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Grid.Row="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat={}{0:T}}" Width="120"/>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80"/>
                        <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyName}" Width="*"/>
                        <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="80"/>
                        <DataGridTextColumn Header="Stake" Binding="{Binding Stake, StringFormat={}{0:F2}}" Width="80"/>
                        <DataGridTextColumn Header="P/L" Binding="{Binding Profit, StringFormat={}{0:F2}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Skip reason box (why last trade was NOT taken) -->
                <Border Grid.Row="1"
                        Margin="0,6,0,0"
                        Padding="4"
                        BorderBrush="#FFCCCCCC"
                        BorderThickness="1"
                        CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="Why last trade was not taken"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="Gray"/>
                        <TextBlock Text="{Binding LastSkipReason}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <!-- ===================== DERIV LOG (BOTTOM) ===================== -->
        <GroupBox Header="Deriv Log" Grid.Row="3" Margin="0,10,0,0">
            <TextBox 
                x:Name="LogTextBox"
                Text="{Binding CombinedLog, Mode=OneWay}" 
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                TextWrapping="NoWrap"
                AcceptsReturn="True"
                FontFamily="Consolas"
                FontSize="12"
                Margin="5"
                TextChanged="LogTextBox_TextChanged"
            />
        </GroupBox>
    </Grid>
</Window>
